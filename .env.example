# ===========================================
# Development Workflow Application
# ===========================================
# Copy this file to .env and fill in values
# NEVER commit .env files to the repository
# ===========================================

# API Configuration
DATABASE_URL=postgresql://devworkflow:password@localhost:5432/devworkflow
SESSION_SECRET=change-me-to-256-bit-random-string

# Admin User (created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-secure-password

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Web Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional: Kubernetes cluster config for deployment feature
# KUBECONFIG_PATH=/path/to/kubeconfig